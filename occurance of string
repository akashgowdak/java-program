package arrayclass;

public class occurance_given_character {
	public static void main(String[] args) {
		String s1="welcome";
		int count=0;
		
		for (int i = 0; i < s1.length(); i++) {
			char ch=s1.charAt(i);
			
		for (int j = 0; j < s1.length(); j++) {
			if(ch==s1.charAt(j))
			{
				count++;
			}}
        if (s1.indexOf(ch) == i) {
            System.out.println(ch + " : " + count);
			}
		}
		}
		}
